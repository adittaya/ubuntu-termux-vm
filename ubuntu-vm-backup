#!/data/data/com.termux/files/usr/bin/bash
#
# Ubuntu VM Backup Script
# ========================
# Creates safe backups of your VM disk image
#

set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m'

VM_DIR="$HOME/storage/shared/ubuntu-vm"
DISK="$VM_DIR/ubuntu-disk.qcow2"
BACKUP_DIR="$HOME/storage/shared/ubuntu-vm/backups"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="$BACKUP_DIR/ubuntu-disk-backup-$TIMESTAMP.qcow2"

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}     Ubuntu VM Backup Script            ${NC}"
echo -e "${GREEN}========================================${NC}"
echo ""

# Check if VM is running
if pgrep -f "qemu-system-aarch64.*ubuntu-disk.qcow2" > /dev/null 2>&1; then
    echo -e "${YELLOW}⚠ Warning: VM is currently running${NC}"
    echo "For best results, shut down the VM first:"
    echo "  shutdown -h now  (inside VM)"
    echo ""
    read -p "Continue with live backup? (y/N): " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Backup cancelled."
        exit 0
    fi
fi

# Check disk exists
if [ ! -f "$DISK" ]; then
    echo -e "${RED}Error: Disk image not found at $DISK${NC}"
    exit 1
fi

# Create backup directory
mkdir -p "$BACKUP_DIR"

# Get disk size
DISK_SIZE=$(du -h "$DISK" | cut -f1)
echo -e "${BLUE}Disk Info:${NC}"
echo "  Location: $DISK"
echo "  Size: $DISK_SIZE"
echo ""

# Create backup
echo -e "${YELLOW}Creating backup...${NC}"
echo "  Destination: $BACKUP_FILE"
echo ""

# Use qemu-img for consistent backup
if command -v qemu-img > /dev/null 2>&1; then
    qemu-img convert -f qcow2 -O qcow2 -c "$DISK" "$BACKUP_FILE"
else
    # Fallback to cp
    cp "$DISK" "$BACKUP_FILE"
fi

# Verify backup
if [ -f "$BACKUP_FILE" ]; then
    BACKUP_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
    echo ""
    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}     Backup Complete!                   ${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo ""
    echo -e "${BLUE}Backup Details:${NC}"
    echo "  File: $BACKUP_FILE"
    echo "  Size: $BACKUP_SIZE"
    echo ""
    
    # List all backups
    echo -e "${BLUE}All Backups:${NC}"
    ls -lh "$BACKUP_DIR"/*.qcow2 2>/dev/null | awk '{print "  " $9 " (" $5 ")"}'
    echo ""
    
    # Keep only last 5 backups
    BACKUP_COUNT=$(ls -1 "$BACKUP_DIR"/*.qcow2 2>/dev/null | wc -l)
    if [ "$BACKUP_COUNT" -gt 5 ]; then
        echo -e "${YELLOW}Cleaning old backups...${NC}"
        ls -t "$BACKUP_DIR"/*.qcow2 | tail -n +6 | xargs rm -f
    fi
else
    echo -e "${RED}Backup failed!${NC}"
    exit 1
fi
