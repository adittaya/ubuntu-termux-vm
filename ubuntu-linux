#!/data/data/com.termux/files/usr/bin/bash
#
# Ubuntu VM Smart Launcher
# =========================
# Automatically detects if Ubuntu is installed and sets boot order
#

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
DIM='\033[2m'
NC='\033[0m'

# Directories
VM_DIR="$HOME/storage/shared/ubuntu-vm"
DISK="$VM_DIR/ubuntu-disk.qcow2"
CLOUD_INIT_ISO="$VM_DIR/cloud-init.iso"
SHARE_DIR="$HOME/ubuntu_share"
UEFI="$PREFIX/share/qemu/edk2-aarch64-code.fd"

# Load settings
if [ -f "$VM_DIR/.vm-settings" ]; then
    source "$VM_DIR/.vm-settings"
else
    CPU_CORES=4
    RAM_SIZE="4G"
    CACHE_MODE="writeback"
    ENABLE_VIRTFS="yes"
    ENABLE_RNG="yes"
    ENABLE_BALLOON="yes"
    MULTI_QUEUE="yes"
fi

# Check if disk has data (Ubuntu installed)
DISK_SIZE=$(stat -c%s "$DISK" 2>/dev/null || echo "0")
if [ "$DISK_SIZE" -gt 100000000 ]; then
    # Disk has data (>100MB), boot from disk first
    BOOT_ORDER="c"
    BOOT_MSG="Booting from installed Ubuntu..."
else
    # Disk is empty/new, boot from CDROM for installation
    BOOT_ORDER="d"
    BOOT_MSG="First boot - Installing Ubuntu from cloud-init..."
fi

echo -e "${GREEN}╔════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║     Ubuntu VM - Smart Launcher                 ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${BLUE}$BOOT_MSG${NC}"
echo -e "${DIM}Boot order: ${BOOT_ORDER} (c=disk, d=CDROM)${NC}"
echo ""
echo -e "${YELLOW}Connect via SSH:${NC}"
echo -e "  ssh -p 2222 root@localhost"
echo ""
echo -e "${DIM}Exit QEMU: Ctrl+A then X${NC}"
echo ""

# QEMU Command
exec qemu-system-aarch64 \
    -M virt,highmem=on \
    -cpu max \
    -smp ${CPU_CORES} \
    -m ${RAM_SIZE} \
    -bios "$UEFI" \
    -drive file="$DISK",if=virtio,cache=$CACHE_MODE,aio=threads,discard=unmap,snapshot=off \
    -drive file="$CLOUD_INIT_ISO",if=virtio,media=cdrom \
    -netdev user,id=n1,hostfwd=tcp::2222-:22,hostfwd=tcp::8080-:8080,hostfwd=tcp::9000-:9000,hostfwd=tcp::7681-:7681 \
    -device virtio-net-pci,netdev=n1 \
    -virtfs local,path="$SHARE_DIR",mount_tag=shared_mount,security_model=none,id=shared_mount \
    -device virtio-rng-pci \
    -device virtio-balloon-pci \
    -nographic \
    -serial mon:stdio \
    -boot order=$BOOT_ORDER
