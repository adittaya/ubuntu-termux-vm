#!/data/data/com.termux/files/usr/bin/bash
#
# Ubuntu VM Launcher for Termux + QEMU
# MAXIMUM PERFORMANCE + DATA SAFETY + FULL AUTO-SETUP
# ================================================================================
# Start: ubuntu or ~/ubuntu-linux
# Exit: Ctrl+A then X
#
# This launcher starts the VM directly with saved settings.
# For interactive console menu with settings, run: ubuntu-vm-console
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
NC='\033[0m' # No Color

# Directories
VM_DIR="$HOME/storage/shared/ubuntu-vm"
DISK="$VM_DIR/ubuntu-disk.qcow2"
CLOUD_IMG="$VM_DIR/ubuntu-cloud.img"
CLOUD_INIT_ISO="$VM_DIR/cloud-init.iso"
SHARE_DIR="$HOME/ubuntu_share"
UEFI="$PREFIX/share/qemu/edk2-aarch64-code.fd"

# Load saved settings or use defaults
if [ -f "$VM_DIR/.vm-settings" ]; then
    source "$VM_DIR/.vm-settings"
else
    # Default Settings
    CPU_CORES=4
    RAM_SIZE="4G"
    CACHE_MODE="writeback"
    ENABLE_VIRTFS="yes"
    ENABLE_RNG="yes"
    ENABLE_BALLOON="yes"
    MULTI_QUEUE="yes"
fi

echo -e "${GREEN}╔════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║     Ubuntu VM - MAX PERFORMANCE                ║${NC}"
echo -e "${GREEN}║     + DATA SAFETY + FULL AUTO-SETUP            ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════════════════╝${NC}"
echo ""

# Check prerequisites
check_prereqs() {
    local missing=0
    
    if [ ! -f "$UEFI" ]; then
        echo -e "${RED}Error: UEFI firmware not found at $UEFI${NC}"
        echo "Install QEMU: pkg install qemu-system-aarch64"
        missing=1
    fi
    
    if [ ! -f "$DISK" ]; then
        echo -e "${RED}Error: Disk image not found at $DISK${NC}"
        missing=1
    fi
    
    if [ $missing -eq 1 ]; then
        echo ""
        echo -e "${YELLOW}Run the setup script first:${NC}"
        echo "  ~/setup-ubuntu-vm.sh"
        exit 1
    fi
}

# Create share directory
mkdir -p "$SHARE_DIR" 2>/dev/null || true

# Check prerequisites
check_prereqs

echo -e "${GREEN}Starting Ubuntu VM...${NC}"
echo -e "  CPU: ${CPU_CORES} cores"
echo -e "  RAM: ${RAM_SIZE}"
echo -e "  Disk Cache: ${CACHE_MODE}"
echo -e "  Disk: ${DISK}"
echo -e "  Share: ${SHARE_DIR} <-> /shared_mount"
echo ""
echo -e "${MAGENTA}════════════════════════════════════════════════${NC}"
echo -e "${BLUE}Data Safety:${NC}"
echo -e "  ✓ writeback cache - Data preserved on shutdown"
echo -e "  ✓ QCOW2 format - Copy-on-write protection"
echo -e "  ✓ Auto-sync on VM exit"
echo ""
echo -e "${BLUE}Auto-Setup:${NC}"
echo -e "  ✓ Root password: root (no prompts)"
echo -e "  ✓ SSH auto-enabled"
echo -e "  ✓ All services auto-start on first boot"
echo -e "${MAGENTA}════════════════════════════════════════════════${NC}"
echo ""
echo -e "${BLUE}Connect via SSH:${NC}"
echo -e "  ssh -p 2222 root@localhost"
echo ""
echo -e "${BLUE}Web Services:${NC}"
echo -e "  VS Code:      http://localhost:8080"
echo -e "  File Browser: http://localhost:9000"
echo -e "  Web Terminal: http://localhost:7681"
echo ""
echo -e "${YELLOW}Exit QEMU: Ctrl+A then X${NC}"
echo -e "${YELLOW}Safe Shutdown: shutdown -h now (inside VM)${NC}"
echo ""
echo -e "${DIM}Tip: Run 'ubuntu-vm-console' for interactive settings menu${NC}"
echo ""

# QEMU Command - MAXIMUM PERFORMANCE + DATA SAFETY + AUTO-SETUP
# Note: Using aio=threads for compatibility (aio=native not available in all QEMU builds)
exec qemu-system-aarch64 \
    -M virt,highmem=on \
    -cpu max \
    -smp ${CPU_CORES} \
    -m ${RAM_SIZE} \
    -bios "$UEFI" \
    -drive file="$DISK",if=virtio,cache=$CACHE_MODE,aio=threads,discard=unmap,snapshot=off \
    -drive file="$CLOUD_INIT_ISO",if=virtio,media=cdrom \
    -netdev user,id=n1,hostfwd=tcp::2222-:22,hostfwd=tcp::8080-:8080,hostfwd=tcp::9000-:9000,hostfwd=tcp::7681-:7681 \
    -device virtio-net-pci,netdev=n1 \
    -virtfs local,path="$SHARE_DIR",mount_tag=shared_mount,security_model=none,id=shared_mount \
    -device virtio-rng-pci \
    -device virtio-balloon-pci \
    -nographic \
    -serial mon:stdio
