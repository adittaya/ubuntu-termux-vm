# UI COMPONENTS
# ═══════════════════════════════════════════════════════════════

# Draw header
draw_header() {
    local w=$((TERM_COLS - 4))
    draw_box 2 1 $w 4 " UBUNTU VM CONSOLE v3.0 " "${COLORS[GREEN]}"
    
    draw_text 4 2 "🐘 Ubuntu VM - Advanced Launcher" "${COLORS[WHITE]}"
    draw_text 4 3 "Auto-Download + Troubleshooting + Full Customization" "${COLORS[CYAN]}"
}

# Draw system info panel
draw_system_panel() {
    local w=38 h=12 x=2 y=6
    
    draw_box $x $y $w $h " SYSTEM INFO " "${COLORS[BLUE]}"
    
    local row=$((y + 1))
    draw_text $((x + 2)) $row "Host CPU: ${SYSTEM[TOTAL_CORES]} cores" "${COLORS[CYAN]}"
    draw_text $((x + 2)) $((row + 1)) "Host RAM: ${SYSTEM[TOTAL_RAM_GB]} GB" "${COLORS[CYAN]}"
    draw_text $((x + 2)) $((row + 2)) "QEMU: ${SYSTEM[QEMU_VERSION]:0:30}" "${COLORS[CYAN]}"
    draw_text $((x + 2)) $((row + 3)) "Storage: ${SYSTEM[STORAGE_FREE]}" "${COLORS[CYAN]}"
    draw_hline $((x + 2)) $((row + 5)) 30 "─" "${COLORS[DIM]}"
    draw_text $((x + 2)) $((row + 6)) "Cloud Image:" "${COLORS[WHITE]}"
    
    if [[ "${SYSTEM[CLOUDIMG_STATUS]}" == "ready" ]]; then
        draw_status $((x + 18)) $((row + 6)) "ready" "Ready"
    else
        draw_status $((x + 18)) $((row + 6)) "missing" "Missing"
    fi
    
    draw_text $((x + 2)) $((row + 7)) "Disk: ${SYSTEM[DISK_SIZE]}" "${COLORS[CYAN]}"
    draw_text $((x + 2)) $((row + 8)) "Backups: ${SYSTEM[BACKUP_COUNT]}" "${COLORS[CYAN]}"
}

# Draw settings panel
draw_settings_panel() {
    local w=45 h=15 x=$((TERM_COLS / 2)) y=6
    
    draw_box $x $y $w $h " VM SETTINGS " "${COLORS[YELLOW]}"
    
    local row=$((y + 1))
    local items=(
        "CPU_CORES:CPU Cores:${SETTINGS[CPU_CORES]} cores"
        "RAM_SIZE:RAM Size:${SETTINGS[RAM_SIZE]}"
        "CACHE_MODE:Disk Cache:${SETTINGS[CACHE_MODE]}"
        "ENABLE_VIRTFS:VirtFS Share:${SETTINGS[ENABLE_VIRTFS]}"
        "ENABLE_RNG:Hardware RNG:${SETTINGS[ENABLE_RNG]}"
        "ENABLE_BALLOON:Mem Balloon:${SETTINGS[ENABLE_BALLOON]}"
        "MULTI_QUEUE:Multi-Queue:${SETTINGS[MULTI_QUEUE]}"
    )
    
    for i in "${!items[@]}"; do
        IFS=':' read -r key label value <<< "${items[$i]}"
        local color="${COLORS[NC]}"
        if [[ "${STATE[current_view]}" == "settings" ]] && [[ $i -eq ${STATE[settings_row]} ]]; then
            color="${COLORS[REVERSE]}${COLORS[GREEN]}"
        fi
        draw_text $((x + 2)) $((row + i)) " [$((i + 1))] $label: $value" "$color"
    done
    
    draw_text $((x + 2)) $((row + 8)) "[R] Reset  [S] Save  [←/→] Change" "${COLORS[DIM]}"
}

# Draw performance panel
draw_performance_panel() {
    local w=38 h=8 x=2 y=$((TERM_ROWS - 10))
    
    draw_box $x $y $w $h " PERFORMANCE " "${COLORS[MAGENTA]}"
    
    # Calculate score
    local score=0
    [[ ${SETTINGS[CPU_CORES]} -ge 4 ]] && score=$((score + 30))
    [[ ${SETTINGS[CPU_CORES]} -ge 6 ]] && score=$((score + 10))
    
    case "${SETTINGS[RAM_SIZE]}" in
        4G) score=$((score + 25)) ;;
        5G|6G) score=$((score + 35)) ;;
        8G) score=$((score + 40)) ;;
        3G) score=$((score + 20)) ;;
        2G) score=$((score + 15)) ;;
        *) score=$((score + 10)) ;;
    esac
    
    case "${SETTINGS[CACHE_MODE]}" in
        unsafe) score=$((score + 20)) ;;
        writeback) score=$((score + 15)) ;;
        none) score=$((score + 10)) ;;
        writethrough) score=$((score + 5)) ;;
    esac
    
    local level="LOW"
    local color="${COLORS[RED]}"
    if [[ $score -ge 90 ]]; then
        level="MAXIMUM"
        color="${COLORS[GREEN]}"
    elif [[ $score -ge 70 ]]; then
        level="HIGH"
        color="${COLORS[CYAN]}"
    elif [[ $score -ge 50 ]]; then
        level="MEDIUM"
        color="${COLORS[YELLOW]}"
    fi
    
    local safety="SAFE"
    local safety_color="${COLORS[GREEN]}"
    if [[ "${SETTINGS[CACHE_MODE]}" == "unsafe" ]]; then
        safety="MODERATE"
        safety_color="${COLORS[YELLOW]}"
    fi
    
    draw_text $((x + 2)) $((y + 1)) "Score: $color$BOLD $level ($score/100) ${COLORS[RESET]}"
    draw_text $((x + 2)) $((y + 2)) "Safety: $safety_color$safety${COLORS[RESET]}"
    
    # Progress bar
    local bar_w=25
    local filled=$((score * bar_w / 100))
    draw_text $((x + 2)) $((y + 3)) "["
    draw_text $((x + 3)) $((y + 3)) "${COLORS[GREEN]}"
    for ((i=0; i<filled; i++)); do echo -n "█"; done
    draw_text $((x + 3 + filled)) $((y + 3)) "${COLORS[DIM]}"
    for ((i=filled; i<bar_w; i++)); do echo -n "░"; done
    draw_text $((x + 3 + bar_w)) $((y + 3)) "]"
}

# Draw actions panel
draw_actions_panel() {
    local w=45 h=10 x=$((TERM_COLS / 2)) y=$((TERM_ROWS - 12))
    
    draw_box $x $y $w $h " ACTIONS " "${COLORS[GREEN]}"
    
    local row=$((y + 1))
    local actions=(
        "START VM - Boot with current settings"
        "Save Settings"
        "Health Check"
        "Backup VM"
        "Download Missing Files"
        "Troubleshooting"
        "Advanced Options"
        "Quit"
    )
    
    for i in "${!actions[@]}"; do
        local color="${COLORS[NC]}"
        local prefix=" "
        if [[ "${STATE[current_view]}" == "actions" ]] && [[ $i -eq ${STATE[main_row]} ]]; then
            color="${COLORS[REVERSE]}${COLORS[GREEN]}"
            prefix="▶"
        fi
        draw_text $((x + 2)) $((row + i)) "$prefix [$((i + 1))] ${actions[$i]}" "$color"
    done
    
    draw_text $((x + 2)) $((row + 8)) "Use ↑↓ to navigate, ENTER to select" "${COLORS[DIM]}"
}

# Draw help bar
draw_help_bar() {
    local y=$((TERM_ROWS - 1))
    draw_hline 1 $y $TERM_COLS "─" "${COLORS[DIM]}"
    
    local help="↑↓ Navigate  ←→ Adjust  ENTER Select  Q Quit"
    draw_text 2 $y "$help" "${COLORS[DIM]}"
}

