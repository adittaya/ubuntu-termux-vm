# ═══════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════

log() {
    local level=$1
    shift
    local msg="$*"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] [$level] $msg" >> "$LOG_FILE"
}

log_info() { log "INFO" "$@"; }
log_warn() { log "WARN" "$@"; }
log_error() { log "ERROR" "$@"; }
log_debug() { log "DEBUG" "$@"; }

# ═══════════════════════════════════════════════════════════════
# UTILITY FUNCTIONS
# ═══════════════════════════════════════════════════════════════

# Hide/show cursor
hide_cursor() { echo -ne "\033[?25l"; }
show_cursor() { echo -ne "\033[?25h"; }

# Clear screen
clear_screen() { clear; }

# Move cursor
move_cursor() { echo -ne "\033[$1;$2H"; }

# Get terminal size
get_term_size() {
    local size=$(stty size 2>/dev/null || echo "24 80")
    TERM_ROWS=${size%% *}
    TERM_COLS=${size##* }
}

# Read key without echo
read_key() {
    local key=""
    IFS= read -r -n1 -s key
    if [[ "$key" == $'\x1b' ]]; then
        IFS= read -r -n2 -s key
        key="$key"
    fi
    echo "$key"
}

# ═══════════════════════════════════════════════════════════════
# DOWNLOAD MANAGER
# ═══════════════════════════════════════════════════════════════

# Check if file exists and is valid
check_file() {
    local file=$1
    local min_size=$2  # minimum size in bytes
    
    if [[ ! -f "$file" ]]; then
        return 1
    fi
    
    if [[ -n "$min_size" ]]; then
        local actual_size=$(stat -c%s "$file" 2>/dev/null || echo "0")
        if [[ $actual_size -lt $min_size ]]; then
            return 2
        fi
    fi
    
    return 0
}

# Download with progress and retry
download_with_progress() {
    local url=$1
    local output=$2
    local description=$3
    local max_retries=${4:-3}
    local min_size=${5:-0}
    
    local attempt=1
    local success=false
    
    while [[ $attempt -le $max_retries ]]; do
        echo ""
        echo -e "${COLORS[CYAN]}Downloading $description (Attempt $attempt/$max_retries)...${COLORS[RESET]}"
        echo -e "${COLORS[DIM]}Source: $url${COLORS[RESET]}"
        echo ""
        
        # Try wget first
        if command -v wget > /dev/null 2>&1; then
            wget -q --show-progress -O "$output.tmp" "$url" 2>&1
            local wget_status=$?
            
            if [[ $wget_status -eq 0 ]]; then
                mv "$output.tmp" "$output"
                success=true
            fi
        # Try curl as fallback
        elif command -v curl > /dev/null 2>&1; then
            curl -# -L -o "$output.tmp" "$url" 2>&1
            local curl_status=$?
            
            if [[ $curl_status -eq 0 ]]; then
                mv "$output.tmp" "$output"
                success=true
            fi
        else
            echo -e "${COLORS[RED]}Error: Neither wget nor curl is available${COLORS[RESET]}"
            log_error "No download tool available"
            return 1
        fi
        
        # Verify download
        if [[ "$success" == "true" ]]; then
            if [[ $min_size -gt 0 ]]; then
                local actual_size=$(stat -c%s "$output" 2>/dev/null || echo "0")
                if [[ $actual_size -lt $min_size ]]; then
                    echo -e "${COLORS[YELLOW]}Warning: Downloaded file too small ($actual_size < $min_size bytes)${COLORS[RESET]}"
                    success=false
                fi
            fi
        fi
        
        if [[ "$success" == "true" ]]; then
            echo -e "${COLORS[GREEN]}✓ Download complete!${COLORS[RESET]}"
            log_info "Downloaded: $description from $url"
            return 0
        else
            echo -e "${COLORS[YELLOW]}Download failed (attempt $attempt)${COLORS[RESET]}"
            log_warn "Download failed: $url (attempt $attempt)"
            rm -f "$output.tmp"
        fi
        
        ((attempt++))
        
        if [[ $attempt -le $max_retries ]]; then
            echo -e "${COLORS[DIM]}Retrying in 2 seconds...${COLORS[RESET]}"
            sleep 2
        fi
    done
    
    echo -e "${COLORS[RED]}✗ All download attempts failed for: $description${COLORS[RESET]}"
    log_error "All download attempts failed: $description"
    return 1
}

# Download with mirror fallback
download_with_fallback() {
    local -n mirrors=$1
    local output=$2
    local description=$3
    local min_size=${4:-0}
    
    echo ""
    echo -e "${COLORS[CYAN]}╔════════════════════════════════════════════════╗${COLORS[RESET]}"
    echo -e "${COLORS[CYAN]}║   Downloading: $description${COLORS[RESET]}"
    echo -e "${COLORS[CYAN]}╚════════════════════════════════════════════════╝${COLORS[RESET]}"
    echo ""
    
    for i in "${!mirrors[@]}"; do
        local mirror="${mirrors[$i]}"
        echo -e "${COLORS[DIM]}Trying mirror $((i+1))/${#mirrors[@]}...${COLORS[RESET]}"
        
        if download_with_progress "$mirror" "$output" "$description" 2 "$min_size"; then
            return 0
        fi
        
        echo ""
    done
    
    echo -e "${COLORS[RED]}╔════════════════════════════════════════════════╗${COLORS[RESET]}"
    echo -e "${COLORS[RED]}║   ERROR: All mirrors failed!                   ║${COLORS[RESET]}"
    echo -e "${COLORS[RED]}╚════════════════════════════════════════════════╝${COLORS[RESET]}"
    echo ""
    
    return 1
}

# Check and download required files
check_and_download_requirements() {
    local missing_files=()
    local need_download=false
    
    echo -e "${COLORS[CYAN]}Checking requirements...${COLORS[RESET]}"
    
    # Check QEMU
    if ! command -v qemu-system-aarch64 > /dev/null 2>&1; then
        echo -e "${COLORS[RED]}✗ QEMU not installed${COLORS[RESET]}"
        echo ""
        echo -e "${COLORS[YELLOW]}Solution:${COLORS[RESET]}"
        echo "  pkg install qemu-system-aarch64"
        echo ""
        read -p "Install now? (y/n): " install_now
        if [[ "$install_now" == "y" ]]; then
            pkg install qemu-system-aarch64
        else
            return 1
        fi
    else
        echo -e "${COLORS[GREEN]}✓ QEMU installed${COLORS[RESET]}"
    fi
    
    # Check UEFI
    if ! check_file "$UEFI" 1000; then
        echo -e "${COLORS[YELLOW]}✗ UEFI firmware missing${COLORS[RESET]}"
        missing_files+=("uefi")
        need_download=true
    else
        echo -e "${COLORS[GREEN]}✓ UEFI firmware found${COLORS[RESET]}"
    fi
    
    # Check Cloud Image
    if ! check_file "$CLOUD_IMG" 100000000; then  # Min 100MB
        echo -e "${COLORS[YELLOW]}✗ Ubuntu cloud image missing${COLORS[RESET]}"
        missing_files+=("cloudimg")
        need_download=true
    else
        echo -e "${COLORS[GREEN]}✓ Ubuntu cloud image found${COLORS[RESET]}"
    fi
    
    # Check Disk
    if ! check_file "$DISK" 0; then
        echo -e "${COLORS[DIM]}- Disk image will be created${COLORS[RESET]}"
    else
        echo -e "${COLORS[GREEN]}✓ Disk image found${COLORS[RESET]}"
    fi
    
    # Check Cloud-init ISO
    if ! check_file "$CLOUD_INIT_ISO" 1000; then
        echo -e "${COLORS[DIM]}- Cloud-init ISO will be generated${COLORS[RESET]}"
    else
        echo -e "${COLORS[GREEN]}✓ Cloud-init ISO found${COLORS[RESET]}"
    fi
    
    echo ""
    
    if [[ "$need_download" == "true" ]]; then
        echo -e "${COLORS[YELLOW]}Some files are missing. Download now?${COLORS[RESET]}"
        read -p "Continue? (y/n): " confirm
        
        if [[ "$confirm" != "y" ]]; then
            echo -e "${COLORS[RED]}Setup cancelled${COLORS[RESET]}"
            return 1
        fi
        
        download_missing_files "${missing_files[@]}"
    fi
    
    return 0
}

# Download specific missing files
download_missing_files() {
    local files=("$@")
    mkdir -p "$DOWNLOAD_DIR"
    
    for file in "${files[@]}"; do
        case "$file" in
            "uefi")
                echo -e "${COLORS[DIM]}UEFI firmware is part of QEMU package${COLORS[RESET]}"
                echo "Reinstall QEMU if missing:"
                echo "  pkg install qemu-system-aarch64 --reinstall"
                ;;
            
            "cloudimg")
                download_with_fallback UBUNTU_MIRRORS "$CLOUD_IMG" "Ubuntu 24.04 Cloud Image" 100000000
                ;;
        esac
    done
}

# Troubleshoot download failures
troubleshoot_download() {
    local resource=$1
    
    clear_screen
    show_cursor
    
    echo -e "${COLORS[RED]}╔════════════════════════════════════════════════╗${COLORS[RESET]}"
    echo -e "${COLORS[RED]}║   TROUBLESHOOTING: $resource${COLORS[RESET]}"
    echo -e "${COLORS[RED]}╚════════════════════════════════════════════════╝${COLORS[RESET]}"
    echo ""
    
    case "$resource" in
        "ubuntu")
            echo -e "${COLORS[YELLOW]}Possible causes:${COLORS[RESET]}"
            echo "  1. Network connection issue"
            echo "  2. All mirrors are down"
            echo "  3. Firewall blocking download"
            echo "  4. Storage permission denied"
            echo ""
            echo -e "${COLORS[YELLOW]}Solutions:${COLORS[RESET]}"
            echo ""
            echo "  ${COLORS[CYAN]}1. Check network:${COLORS[RESET]}"
            echo "     ping -c 3 cloud-images.ubuntu.com"
            echo ""
            echo "  ${COLORS[CYAN]}2. Try manual download:${COLORS[RESET]}"
            echo "     wget https://cloud-images.ubuntu.com/releases/24.04/release/ubuntu-24.04-server-cloudimg-arm64.img -O $CLOUD_IMG"
            echo ""
            echo "  ${COLORS[CYAN]}3. Check storage:${COLORS[RESET]}"
            echo "     termux-setup-storage"
            echo ""
            echo "  ${COLORS[CYAN]}4. Use alternative mirror:${COLORS[RESET]}"
            echo "     wget https://mirrors.edge.kernel.org/ubuntu-cloud/releases/24.04/release/ubuntu-24.04-server-cloudimg-arm64.img -O $CLOUD_IMG"
            echo ""
            ;;
        
        "qemu")
            echo -e "${COLORS[YELLOW]}QEMU not installed${COLORS[RESET]}"
            echo ""
            echo -e "${COLORS[CYAN]}Install command:${COLORS[RESET]}"
            echo "  pkg update && pkg install qemu-system-aarch64 xorriso"
            echo ""
            ;;
    esac
    
    echo ""
    echo -e "${COLORS[DIM]}Press any key to return to menu...${COLORS[RESET]}"
    read -n1 -s
}

# ═══════════════════════════════════════════════════════════════
# SYSTEM SCANNING
# ═══════════════════════════════════════════════════════════════

scan_system() {
    # CPU Info
    SYSTEM[TOTAL_CORES]=$(nproc 2>/dev/null || echo "4")
    SYSTEM[CPU_MODEL]=$(cat /proc/cpuinfo 2>/dev/null | grep "model name" | head -1 | cut -d: -f2 | xargs || echo "Unknown")
    
    # Memory Info
    local mem_kb=$(grep MemTotal /proc/meminfo 2>/dev/null | awk '{print $2}' || echo "4194304")
    SYSTEM[TOTAL_RAM_GB]=$((mem_kb / 1024 / 1024))
    SYSTEM[AVAILABLE_RAM]=$(free -h 2>/dev/null | awk 'NR==2{print $7}' || echo "N/A")
    
    # Storage Info
    if [ -f "$DISK" ]; then
        SYSTEM[DISK_SIZE]=$(du -h "$DISK" 2>/dev/null | cut -f1 || echo "N/A")
        SYSTEM[DISK_FORMAT]=$(qemu-img info "$DISK" 2>/dev/null | grep "file format" | awk '{print $3}' || echo "N/A")
        SYSTEM[VIRT_SIZE]=$(qemu-img info "$DISK" 2>/dev/null | grep "virtual size" | awk -F'(' '{print $2}' | awk -F')' '{print $1}' || echo "N/A")
    else
        SYSTEM[DISK_SIZE]="Not created"
        SYSTEM[DISK_FORMAT]="N/A"
        SYSTEM[VIRT_SIZE]="N/A"
    fi
    
    # QEMU Info
    SYSTEM[QEMU_VERSION]=$(qemu-system-aarch64 --version 2>&1 | head -1 | cut -d'(' -f1 || echo "Unknown")
    
    # KVM Support
    if [ -e /dev/kvm ]; then
        SYSTEM[KVM_SUPPORT]="yes"
    else
        SYSTEM[KVM_SUPPORT]="no"
    fi
    
    # Network Info
    SYSTEM[HOST_IP]=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "N/A")
    
    # Backup Count
    SYSTEM[BACKUP_COUNT]=$(ls -1 "$BACKUP_DIR"/*.qcow2 2>/dev/null | wc -l || echo "0")
    
    # Last Backup
    if [ "$SYSTEM[BACKUP_COUNT]" -gt 0 ]; then
        SYSTEM[LAST_BACKUP]=$(ls -t "$BACKUP_DIR"/*.qcow2 2>/dev/null | head -1 | xargs basename 2>/dev/null | cut -d'-' -f4- | cut -d'.' -f1 || echo "N/A")
    else
        SYSTEM[LAST_BACKUP]="None"
    fi
    
    # Download Status
    SYSTEM[CLOUDIMG_STATUS]="missing"
    if check_file "$CLOUD_IMG" 100000000; then
        SYSTEM[CLOUDIMG_STATUS]="ready"
    fi
    
    # Storage Space
    SYSTEM[STORAGE_FREE]=$(df -h "$VM_DIR" 2>/dev/null | awk 'NR==2{print $4}' || echo "N/A")
}

# ═══════════════════════════════════════════════════════════════
# SETTINGS MANAGEMENT
# ═══════════════════════════════════════════════════════════════

load_settings() {
    # Start with defaults
    for key in "${!DEFAULTS[@]}"; do
        SETTINGS[$key]="${DEFAULTS[$key]}"
    done
    
    # Load saved settings if exist
    if [ -f "$SETTINGS_FILE" ]; then
        while IFS='=' read -r key value; do
            [[ "$key" =~ ^#.*$ ]] && continue
            [[ -z "$key" ]] && continue
            key=$(echo "$key" | tr -d ' ')
            value=$(echo "$value" | tr -d ' ')
            if [[ -n "$key" ]] && [[ -n "$value" ]]; then
                SETTINGS[$key]="$value"
            fi
        done < "$SETTINGS_FILE"
    fi
}

save_settings() {
    cat > "$SETTINGS_FILE" << EOF
# Ubuntu VM Settings
# Generated: $(date)
CPU_CORES=${SETTINGS[CPU_CORES]}
RAM_SIZE=${SETTINGS[RAM_SIZE]}
CACHE_MODE=${SETTINGS[CACHE_MODE]}
ENABLE_VIRTFS=${SETTINGS[ENABLE_VIRTFS]}
ENABLE_RNG=${SETTINGS[ENABLE_RNG]}
ENABLE_BALLOON=${SETTINGS[ENABLE_BALLOON]}
MULTI_QUEUE=${SETTINGS[MULTI_QUEUE]}
HIGHMEM=${SETTINGS[HIGHMEM]}
AIO_MODE=${SETTINGS[AIO_MODE]}
DISCARD_MODE=${SETTINGS[DISCARD_MODE]}
EOF
    return 0
}

reset_settings() {
    for key in "${!DEFAULTS[@]}"; do
        SETTINGS[$key]="${DEFAULTS[$key]}"
    done
}

# ═══════════════════════════════════════════════════════════════
# DRAWING FUNCTIONS
# ═══════════════════════════════════════════════════════════════

# Draw box
draw_box() {
    local x=$1 y=$2 w=$3 h=$4 title="${5:-}" color="${6:-${COLORS[WHITE]}}"
    
    echo -ne "$color"
    
    # Top border
    move_cursor $y $x
    echo -n "╔"
    for ((i=0; i<w-2; i++)); do echo -n "═"; done
    echo -n "╗"
    
    # Title
    if [[ -n "$title" ]]; then
        move_cursor $y $((x + (w - ${#title}) / 2))
        echo -n " $title "
    fi
    
    # Side borders
    for ((i=1; i<h-1; i++)); do
        move_cursor $((y + i)) $x
        echo -n "║"
        move_cursor $((y + i)) $((x + w - 1))
        echo -n "║"
    done
    
    # Bottom border
    move_cursor $((y + h - 1)) $x
    echo -n "╚"
    for ((i=0; i<w-2; i++)); do echo -n "═"; done
    echo -n "╝"
    
    echo -ne "${COLORS[RESET]}"
}

# Draw text at position
draw_text() {
    local x=$1 y=$2 text="${3:-}" color="${4:-${COLORS[NC]}}" max_width="${5:-0}"
    
    if [[ $max_width -gt 0 ]] && [[ ${#text} -gt $max_width ]]; then
        text="${text:0:$((max_width-3))}..."
    fi
    
    move_cursor $y $x
    echo -ne "$color$text${COLORS[RESET]}"
}

# Draw horizontal line
draw_hline() {
    local x=$1 y=$2 w=$3 char="${4:-─}" color="${5:-${COLORS[DIM]}}"
    
    move_cursor $y $x
    echo -ne "$color"
    for ((i=0; i<w; i++)); do echo -n "$char"; done
    echo -ne "${COLORS[RESET]}"
}

# Draw filled box
draw_filled_box() {
    local x=$1 y=$2 w=$3 h=$4 color="${5:-${COLORS[DIM]}}"
    
    echo -ne "$color"
    for ((i=0; i<h; i++)); do
        move_cursor $((y + i)) $x
        for ((j=0; j<w; j++)); do echo -n " "; done
    done
    echo -ne "${COLORS[RESET]}"
}

# Draw status indicator
draw_status() {
    local x=$1 y=$2 status=$3 label=$4
    
    local icon="${COLORS[RED]}✗${COLORS[RESET]}"
    local color="${COLORS[RED]}"
    
    if [[ "$status" == "ready" ]] || [[ "$status" == "yes" ]]; then
        icon="${COLORS[GREEN]}✓${COLORS[RESET]}"
        color="${COLORS[GREEN]}"
    elif [[ "$status" == "downloading" ]]; then
        icon="${COLORS[YELLOW]}⟳${COLORS[RESET]}"
        color="${COLORS[YELLOW]}"
    fi
    
    draw_text $x $y "$icon $label" "$color"
}

