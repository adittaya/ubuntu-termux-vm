BACKUP_DIR="$VM_DIR/backups"
DOWNLOAD_DIR="$VM_DIR/downloads"
LOG_FILE="$VM_DIR/console.log"

# Default Settings
declare -A DEFAULTS=(
    [CPU_CORES]=4
    [RAM_SIZE]="4G"
    [CACHE_MODE]="writeback"
    [ENABLE_VIRTFS]="yes"
    [ENABLE_RNG]="yes"
    [ENABLE_BALLOON]="yes"
    [MULTI_QUEUE]="yes"
    [HIGHMEM]="yes"
    [AIO_MODE]="native"
    [DISCARD_MODE]="unmap"
)

# Current Settings (will be loaded)
declare -A SETTINGS=()

# System Info (dynamic)
declare -A SYSTEM=()

# Menu State
declare -A STATE=(
    [main_row]=0
    [main_col]=0
    [settings_row]=0
    [advanced_row]=0
    [current_view]="main"
)

# Download Sources (mirrors for fallback)
declare -a UBUNTU_MIRRORS=(
    "https://cloud-images.ubuntu.com/releases/24.04/release/ubuntu-24.04-server-cloudimg-arm64.img"
    "https://mirrors.edge.kernel.org/ubuntu-cloud/releases/24.04/release/ubuntu-24.04-server-cloudimg-arm64.img"
    "https://mirror.clarkson.edu/ubuntu-cloud/releases/24.04/release/ubuntu-24.04-server-cloudimg-arm64.img"
)

declare -a FILEBROWSER_MIRRORS=(
    "https://github.com/filebrowser/filebrowser/releases/download/v2.31.2/linux-arm64-filebrowser.tar.gz"
    "https://mirror.ghproxy.com/https://github.com/filebrowser/filebrowser/releases/download/v2.31.2/linux-arm64-filebrowser.tar.gz"
)

declare -a TTYD_MIRRORS=(
    "https://github.com/tsl0922/ttyd/releases/download/1.7.4/ttyd.aarch64"
    "https://mirror.ghproxy.com/https://github.com/tsl0922/ttyd/releases/download/1.7.4/ttyd.aarch64"
