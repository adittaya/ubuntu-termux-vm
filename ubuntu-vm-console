# MAIN LOOP
# ═══════════════════════════════════════════════════════════════

cleanup() {
    show_cursor
    clear
    echo -e "${COLORS[CYAN]}Goodbye!${COLORS[RESET]}"
}

trap cleanup SIGINT SIGTERM

main() {
    # Initialize
    mkdir -p "$DOWNLOAD_DIR"
    scan_system
    load_settings
    hide_cursor
    get_term_size
    
    # Check requirements on first run
    if ! check_file "$UEFI" 1000 || ! check_file "$CLOUD_IMG" 100000000; then
        clear_screen
        show_cursor
        echo -e "${COLORS[YELLOW]}╔════════════════════════════════════════════════╗${COLORS[RESET]}"
        echo -e "${COLORS[YELLOW]}║     Missing Files Detected                     ║${COLORS[RESET]}"
        echo -e "${COLORS[YELLOW]}╚════════════════════════════════════════════════╝${COLORS[RESET]}"
        echo ""
        echo "Some required files are missing."
        echo "Would you like to download them now?"
        echo ""
        read -p "Continue? (y/n): " confirm
        
        if [[ "$confirm" == "y" ]]; then
            check_and_download_requirements
        fi
    fi
    
    # Main loop
    while true; do
        draw_screen
        handle_input
    done
}

# Check prerequisites
if ! command -v qemu-system-aarch64 > /dev/null 2>&1; then
    echo -e "${COLORS[RED]}Error: QEMU not installed${COLORS[RESET]}"
    echo "Run: pkg install qemu-system-aarch64"
    exit 1
fi

# Run
main
