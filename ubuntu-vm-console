run_troubleshooting() {
    clear_screen
    show_cursor
    
    echo -e "${COLORS[YELLOW]}╔════════════════════════════════════════════════╗${COLORS[RESET]}"
    echo -e "${COLORS[YELLOW]}║     Troubleshooting                            ║${COLORS[RESET]}"
    echo -e "${COLORS[YELLOW]}╚════════════════════════════════════════════════╝${COLORS[RESET]}"
    echo ""
    echo "Select resource to troubleshoot:"
    echo ""
    echo "  [1] Ubuntu Cloud Image Download"
    echo "  [2] QEMU Installation"
    echo "  [3] Network Connection"
    echo "  [4] Storage Permissions"
    echo "  [5] VM Won't Start"
    echo ""
    echo "  [B] Back"
    echo ""
    
    while true; do
        read -n1 -s choice
        case "$choice" in
            1) troubleshoot_download "ubuntu" ;;
            2) troubleshoot_download "qemu" ;;
            3)
                echo -e "${COLORS[CYAN]}Network Diagnostics:${COLORS[RESET]}"
                ping -c 3 cloud-images.ubuntu.com 2>&1 | head -5
                echo -e "${COLORS[DIM]}Press any key...${COLORS[RESET]}"
                read -n1 -s
                ;;
            4)
                echo -e "${COLORS[CYAN]}Storage Check:${COLORS[RESET]}"
                ls -la "$VM_DIR" 2>&1 | head -5
                echo -e "${COLORS[DIM]}Press any key...${COLORS[RESET]}"
                read -n1 -s
                ;;
            5)
                echo -e "${COLORS[CYAN]}VM Startup Troubleshooting:${COLORS[RESET]}"
                echo "1. Check if UEFI exists: ls -la $UEFI"
                echo "2. Check if cloud image exists: ls -la $CLOUD_IMG"
                echo "3. Check disk image: qemu-img check $DISK"
                echo ""
                echo "Run diagnostics? (y/n): "
                read -n1 -s diag
                if [[ "$diag" == "y" ]]; then
                    ls -la "$UEFI" "$CLOUD_IMG" "$DISK" 2>&1
                fi
                echo -e "${COLORS[DIM]}Press any key...${COLORS[RESET]}"
                read -n1 -s
                ;;
            [bB]) return ;;
        esac
    done
}

show_advanced_menu() {
    clear_screen
    show_cursor
    
    echo -e "${COLORS[CYAN]}╔════════════════════════════════════════════════╗${COLORS[RESET]}"
    echo -e "${COLORS[CYAN]}║     Advanced Options                           ║${COLORS[RESET]}"
    echo -e "${COLORS[CYAN]}╚════════════════════════════════════════════════╝${COLORS[RESET]}"
    echo ""
    echo "  [1] Change Disk Image"
    echo "  [2] Network Configuration"
    echo "  [3] Custom QEMU Flags"
    echo "  [4] Performance Profiles"
    echo "  [5] View Logs"
    echo ""
    echo "  [B] Back"
    echo ""
    
    read -n1 -s choice
    case "$choice" in
        5)
            if [ -f "$LOG_FILE" ]; then
                tail -20 "$LOG_FILE"
            else
                echo "No logs yet"
            fi
            echo -e "${COLORS[DIM]}Press any key...${COLORS[RESET]}"
            read -n1 -s
            ;;
    esac
}

