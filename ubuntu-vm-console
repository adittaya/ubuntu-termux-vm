# ═══════════════════════════════════════════════════════════════
# INPUT HANDLING
# ═══════════════════════════════════════════════════════════════

handle_input() {
    local key=$(read_key)
    
    case "$key" in
        # Up arrow
        $'\x1b[A')
            if [[ "${STATE[current_view]}" == "actions" ]]; then
                STATE[main_row]=$(( (STATE[main_row] - 1 + 8) % 8 ))
            elif [[ "${STATE[current_view]}" == "settings" ]]; then
                STATE[settings_row]=$(( (STATE[settings_row] - 1 + 7) % 7 ))
            fi
            ;;
        
        # Down arrow
        $'\x1b[B')
            if [[ "${STATE[current_view]}" == "actions" ]]; then
                STATE[main_row]=$(( (STATE[main_row] + 1) % 8 ))
            elif [[ "${STATE[current_view]}" == "settings" ]]; then
                STATE[settings_row]=$(( (STATE[settings_row] + 1) % 7 ))
            fi
            ;;
        
        # Left arrow
        $'\x1b[D')
            adjust_setting -1
            ;;
        
        # Right arrow
        $'\x1b[C')
            adjust_setting +1
            ;;
        
        # Enter
        "")
            execute_action
            ;;
        
        # Number keys 1-7
        [1-7])
            local num=$((key - 1))
            if [[ $num -lt 7 ]]; then
                STATE[settings_row]=$num
                STATE[current_view]="settings"
                adjust_setting +1
            fi
            ;;
        
        # Q/q - Quit
        [qQ])
            cleanup
            exit 0
            ;;
        
        # R/r - Reset
        [rR])
            reset_settings
            ;;
        
        # S/s - Save
        [sS])
            save_settings
            ;;
    esac
}

# Adjust setting based on direction
adjust_setting() {
    local dir=$1
    local row=${STATE[settings_row]}
    
    case $row in
        0) # CPU Cores
            local options=(1 2 3 4 6 8)
            local current=${SETTINGS[CPU_CORES]}
            for i in "${!options[@]}"; do
                if [[ ${options[$i]} -eq $current ]]; then
                    local new_idx=$(( (i + dir + ${#options[@]}) % ${#options[@]} ))
                    SETTINGS[CPU_CORES]=${options[$new_idx]}
                    break
                fi
            done
            ;;
        1) # RAM Size
            local options=("1G" "2G" "3G" "4G" "5G" "6G" "8G")
            local current=${SETTINGS[RAM_SIZE]}
            for i in "${!options[@]}"; do
                if [[ "${options[$i]}" == "$current" ]]; then
                    local new_idx=$(( (i + dir + ${#options[@]}) % ${#options[@]} ))
                    SETTINGS[RAM_SIZE]=${options[$new_idx]}
                    break
                fi
            done
            ;;
        2) # Cache Mode
            local options=("unsafe" "writeback" "none" "writethrough")
            local current=${SETTINGS[CACHE_MODE]}
            for i in "${!options[@]}"; do
                if [[ "${options[$i]}" == "$current" ]]; then
                    local new_idx=$(( (i + dir + ${#options[@]}) % ${#options[@]} ))
                    SETTINGS[CACHE_MODE]=${options[$new_idx]}
                    break
                fi
            done
            ;;
        3|4|5|6) # Toggle options
            local keys=("ENABLE_VIRTFS" "ENABLE_RNG" "ENABLE_BALLOON" "MULTI_QUEUE")
            local key=${keys[$((row - 3))]}
            if [[ "${SETTINGS[$key]}" == "yes" ]]; then
                SETTINGS[$key]="no"
            else
                SETTINGS[$key]="yes"
            fi
            ;;
    esac
}

# Execute selected action
execute_action() {
    local row=${STATE[main_row]}
    
    case $row in
        0) # Start VM
            start_vm
            ;;
        1) # Save Settings
            save_settings
            ;;
        2) # Health Check
            run_health_check
            ;;
        3) # Backup VM
            run_backup
            ;;
        4) # Download Missing Files
            run_download_manager
            ;;
        5) # Troubleshooting
            run_troubleshooting
            ;;
        6) # Advanced Options
            show_advanced_menu
            ;;
        7) # Quit
            cleanup
            exit 0
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════
# VM OPERATIONS
# ═══════════════════════════════════════════════════════════════

start_vm() {
    # Check requirements first
    if ! check_file "$UEFI" 1000; then
        echo -e "${COLORS[RED]}UEFI firmware missing!${COLORS[RESET]}"
        echo "Please run download manager first."
        sleep 2
        return
    fi
    
    if ! check_file "$CLOUD_IMG" 100000000; then
        echo -e "${COLORS[RED]}Ubuntu cloud image missing!${COLORS[RESET]}"
        echo "Please run download manager first."
        sleep 2
        return
    fi
    
    clear_screen
    show_cursor
    
    echo -e "${COLORS[GREEN]}╔════════════════════════════════════════════════╗${COLORS[RESET]}"
    echo -e "${COLORS[GREEN]}║${COLORS[WHITE]}          STARTING UBUNTU VM                        ${COLORS[GREEN]}║${COLORS[RESET]}"
    echo -e "${COLORS[GREEN]}╚════════════════════════════════════════════════╝${COLORS[RESET]}"
    echo ""
    echo -e "${COLORS[WHITE]}Configuration:${COLORS[RESET]}"
    echo -e "  CPU Cores:      ${COLORS[GREEN]}${SETTINGS[CPU_CORES]}${COLORS[RESET]}"
    echo -e "  RAM:            ${COLORS[GREEN]}${SETTINGS[RAM_SIZE]}${COLORS[RESET]}"
    echo -e "  Disk Cache:     ${COLORS[GREEN]}${SETTINGS[CACHE_MODE]}${COLORS[RESET]}"
    echo -e "  VirtFS:         ${COLORS[GREEN]}${SETTINGS[ENABLE_VIRTFS]}${COLORS[RESET]}"
    echo -e "  Hardware RNG:   ${COLORS[GREEN]}${SETTINGS[ENABLE_RNG]}${COLORS[RESET]}"
    echo -e "  Memory Balloon: ${COLORS[GREEN]}${SETTINGS[ENABLE_BALLOON]}${COLORS[RESET]}"
    echo -e "  Multi-Queue:    ${COLORS[GREEN]}${SETTINGS[MULTI_QUEUE]}${COLORS[RESET]}"
    echo ""
    echo -e "${COLORS[YELLOW]}Starting QEMU...${COLORS[RESET]}"
    echo -e "${COLORS[DIM]}Press Ctrl+A then X to exit VM${COLORS[RESET]}"
    echo ""
    sleep 2
    
    # Build QEMU command
    local cmd="qemu-system-aarch64"
    cmd+=" -M virt"
    [[ "${SETTINGS[HIGHMEM]}" == "yes" ]] && cmd+=",highmem=on"
    cmd+=" -cpu max"
    cmd+=" -smp ${SETTINGS[CPU_CORES]}"
    cmd+=" -m ${SETTINGS[RAM_SIZE]}"
    cmd+=" -bios \"$UEFI\""
    cmd+=" -drive file=\"$DISK\",if=virtio,cache=${SETTINGS[CACHE_MODE]},aio=${SETTINGS[AIO_MODE]},discard=${SETTINGS[DISCARD_MODE]},snapshot=off"
    cmd+=" -drive file=\"$CLOUD_INIT_ISO\",if=virtio,media=cdrom"
    cmd+=" -netdev user,id=n1,hostfwd=tcp::2222-:22,hostfwd=tcp::8080-:8080,hostfwd=tcp::9000-:9000,hostfwd=tcp::7681-:7681"
    cmd+=" -device virtio-net-pci,netdev=n1"
    [[ "${SETTINGS[MULTI_QUEUE]}" == "yes" ]] && cmd+=",mq=on"
    
    if [[ "${SETTINGS[ENABLE_VIRTFS]}" == "yes" ]]; then
        cmd+=" -virtfs local,path=\"$SHARE_DIR\",mount_tag=shared_mount,security_model=none,id=shared_mount"
    fi
    
    [[ "${SETTINGS[ENABLE_RNG]}" == "yes" ]] && cmd+=" -device virtio-rng-pci"
    [[ "${SETTINGS[ENABLE_BALLOON]}" == "yes" ]] && cmd+=" -device virtio-balloon-pci"
    cmd+=" -nographic -serial mon:stdio"
    
    eval $cmd
}

run_health_check() {
    clear_screen
    show_cursor
    
    echo -e "${COLORS[CYAN]}╔════════════════════════════════════════════════╗${COLORS[RESET]}"
    echo -e "${COLORS[CYAN]}║     VM Health Check                            ║${COLORS[RESET]}"
    echo -e "${COLORS[CYAN]}╚════════════════════════════════════════════════╝${COLORS[RESET]}"
    echo ""
    
    # Check disk
    if command -v qemu-img > /dev/null 2>&1 && [ -f "$DISK" ]; then
        echo -e "${COLORS[WHITE]}Disk Integrity:${COLORS[RESET]}"
        qemu-img check "$DISK" 2>&1 | head -10
    else
        echo -e "${COLORS[YELLOW]}Disk not found${COLORS[RESET]}"
    fi
    
    echo ""
    echo -e "${COLORS[DIM]}Press any key to continue...${COLORS[RESET]}"
    read -n1 -s
}

run_backup() {
    clear_screen
    show_cursor
    
    if [ -x ~/ubuntu-vm-backup ]; then
        ~/ubuntu-vm-backup
    else
        echo -e "${COLORS[RED]}Backup script not found${COLORS[RESET]}"
    fi
    
    echo ""
    echo -e "${COLORS[DIM]}Press any key to continue...${COLORS[RESET]}"
    read -n1 -s
}

