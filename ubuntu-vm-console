set -e

# ═══════════════════════════════════════════════════════════════
# CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Colors
declare -A COLORS=(
    [RED]='\033[0;31m'
    [GREEN]='\033[0;32m'
    [YELLOW]='\033[1;33m'
    [BLUE]='\033[0;34m'
    [MAGENTA]='\033[0;35m'
    [CYAN]='\033[0;36m'
    [WHITE]='\033[1;37m'
    [DIM]='\033[2m'
    [BOLD]='\033[1m'
    [REVERSE]='\033[7m'
    [HIDDEN]='\033[8m'
    [RESET]='\033[0m'
)

# Directories
VM_DIR="$HOME/storage/shared/ubuntu-vm"
DISK="$VM_DIR/ubuntu-disk.qcow2"
CLOUD_IMG="$VM_DIR/ubuntu-cloud.img"
CLOUD_INIT_ISO="$VM_DIR/cloud-init.iso"
SHARE_DIR="$HOME/ubuntu_share"
UEFI="$PREFIX/share/qemu/edk2-aarch64-code.fd"
